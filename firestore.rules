rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email == "murnihikmahjome@gmail.com" && request.auth.token.email_verified == true || 
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'));
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && (request.resource.data.role != 'super_admin' || isAdmin());
      allow update: if isOwner(uid) && (request.resource.data.role == resource.data.role || isAdmin());
    }

    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.contractorId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.contractorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();

      match /milestones/{milestoneId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
      }
    }

    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.userId);
    }
  }
}
