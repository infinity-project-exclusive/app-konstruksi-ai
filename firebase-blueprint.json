{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile containing authentication and application roles.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique Firebase Auth ID." },
        "name": { "type": "string", "description": "Display name of the user." },
        "email": { "type": "string", "format": "email", "description": "Email address of the user." },
        "role": { 
          "type": "string", 
          "enum": ["super_admin", "contractor", "customer"], 
          "description": "Access control role." 
        },
        "credits": { "type": "number", "description": "Number of AI credits remaining." }
      },
      "required": ["uid", "email", "role"]
    },
    "Project": {
      "title": "Project",
      "description": "Construction or design project managed by a contractor.",
      "type": "object",
      "properties": {
        "contractorId": { "type": "string", "description": "UID of the contractor owner." },
        "title": { "type": "string", "description": "Project title." },
        "clientName": { "type": "string", "description": "Name of the client." },
        "status": { "type": "string", "enum": ["planning", "in_progress", "completed"] },
        "progress": { "type": "number", "description": "Completion percentage." },
        "shareToken": { "type": "string", "description": "Unique token for client portal access." }
      },
      "required": ["contractorId", "title", "shareToken"]
    },
    "Milestone": {
      "title": "Milestone",
      "description": "A specific stage or task within a project.",
      "type": "object",
      "properties": {
        "projectId": { "type": "string", "description": "Reference to the project." },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "isCompleted": { "type": "boolean" },
        "completedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["projectId", "title", "isCompleted"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System event or update for a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Target user UID." },
        "type": { "type": "string", "enum": ["milestone", "credits", "system"] },
        "message": { "type": "string" },
        "isRead": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "message", "isRead", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "Collection of user documents."
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Collection of projects."
    },
    "/projects/{projectId}/milestones/{milestoneId}": {
      "schema": "Milestone",
      "description": "Sub-collection of project milestones."
    },
    "/notifications/{notifId}": {
      "schema": "Notification",
      "description": "User notifications."
    }
  }
}
